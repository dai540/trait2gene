<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ summary.project }} report</title>
    <link rel="stylesheet" href="styles.css">
  </head>
  <body>
    <main class="shell">
      <header class="hero">
        <p class="eyebrow">trait2gene summary</p>
        <h1>{{ summary.project }}</h1>
        <p class="subtitle">Trait: {{ summary.trait }} | Mode: {{ summary.mode }}</p>
      </header>

      <section class="grid">
        <article class="card">
          <h2>Counts</h2>
          <ul>
            <li>Prioritized genes: {{ summary.counts.prioritized_genes }}</li>
            <li>Ranked genes: {{ summary.counts.all_ranked_genes }}</li>
            <li>Top features: {{ summary.counts.top_features }}</li>
          </ul>
        </article>

        <article class="card">
          <h2>Artifacts</h2>
          <ul>
            <li>Prioritized: {{ summary.outputs.prioritized_genes }}</li>
            <li>All ranked: {{ summary.outputs.all_genes_ranked }}</li>
            <li>Top features: {{ summary.outputs.top_features }}</li>
          </ul>
        </article>
      </section>

      <section class="card">
        <h2>Resources</h2>
        <pre>{{ summary.resources | tojson(indent=2) }}</pre>
      </section>
    </main>
  </body>
</html>
